        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^25.6.2",
        "@types/ws": "^8.18.1",
        "rimraf": "^6.0.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
    }
}
