{
    "name": "browserpowers",
    "version": "1.0.0",
    "private": true,
    "description": "Core server for multi-browser LLM agent — MCP, REST, CLI, and WebSocket",
    "author": "lirrensi",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lirrensi/BrowserPowers.git"
    },
    "bugs": {
        "url": "https://github.com/lirrensi/BrowserPowers/issues"
    },
